@page "/wcs-simulation/base"

@using MudBlazor
@using LY_WebUI_Mudblazor_net8.Components.Pages.WCS_Simulation.Base.Models
@using LY_WebUI_Mudblazor_net8.Components.Pages.WCS_Simulation.Base.Services

@inject IWcsTaskHttpService TaskHttpService

<MudContainer MaxWidth="MaxWidth.False" Class="pa-4 wcs-page">
    <MudStack Row="true" AlignItems="AlignItems.Center" Justify="Justify.SpaceBetween" Class="mb-4">
        <MudStack Spacing="0">
            <MudText Typo="Typo.h4">WCS 任务下发模拟台</MudText>
            <MudText Typo="Typo.body2" Color="Color.Secondary">用于模拟 WCS 向其他系统下发任务（当前为硬编码数据）</MudText>
        </MudStack>
        <MudChip T="string" Color="Color.Info" Variant="Variant.Filled" Icon="@Icons.Material.Filled.Memory">
            Simulation Mode
        </MudChip>
    </MudStack>

    <MudGrid Spacing="3">
        <!-- 参数配置 -->
        <MudItem xs="12" md="4" Class="top-module">
            <MudCard Class="modern-card h-100">
                <MudCardHeader>
                    <CardHeaderContent>
                        <MudText Typo="Typo.h6">
                            <MudIcon Icon="@Icons.Material.Filled.Tune" Class="mr-2" />
                            参数配置
                        </MudText>
                    </CardHeaderContent>
                </MudCardHeader>
                <MudCardContent Class="module-scroll">
                    <MudStack Spacing="2">
                        <MudSelect T="string" Label="目标系统" Variant="Variant.Outlined" Dense="true" @bind-Value="_config.TargetSystem">
                            @foreach (var s in _targetSystems)
                            {
                                <MudSelectItem T="string" Value="@s">@s</MudSelectItem>
                            }
                        </MudSelect>

                        <MudTextField Label="仓库名"
                                      Variant="Variant.Outlined"
                                      Dense="true"
                                      @bind-Value="_config.WarehouseName" />

                        <MudSelect T="string" Label="任务类型" Variant="Variant.Outlined" Dense="true" @bind-Value="_config.TaskType">
                            @foreach (var t in _taskTypes)
                            {
                                <MudSelectItem T="string" Value="@t">@t</MudSelectItem>
                            }
                        </MudSelect>

                        <MudSelect T="int" Label="默认优先级" Variant="Variant.Outlined" Dense="true" @bind-Value="_config.DefaultPriority">
                            @for (var i = 1; i <= 5; i++)
                            {
                                <MudSelectItem T="int" Value="@i">@i</MudSelectItem>
                            }
                        </MudSelect>

                        <MudSwitch T="bool" Color="Color.Primary" @bind-Value="_config.AutoAck">自动确认回执</MudSwitch>

                        <MudStack Row="true" Spacing="1" Class="mt-2 flex-wrap-gap">
                            <MudButton Variant="Variant.Filled" Color="Color.Primary" StartIcon="@Icons.Material.Filled.Save" OnClick="SaveConfig">
                                保存配置
                            </MudButton>
                            <MudButton Variant="Variant.Outlined" Color="Color.Default" StartIcon="@Icons.Material.Filled.RestartAlt" OnClick="ResetConfig">
                                重置
                            </MudButton>
                        </MudStack>
                    </MudStack>
                </MudCardContent>
            </MudCard>
        </MudItem>

        <!-- 任务下发 -->
        <MudItem xs="12" md="4" Class="top-module">
            <MudCard Class="modern-card h-100">
                <MudCardHeader>
                    <CardHeaderContent>
                        <MudText Typo="Typo.h6">
                            <MudIcon Icon="@Icons.Material.Filled.Send" Class="mr-2" />
                            任务下发
                        </MudText>
                    </CardHeaderContent>
                </MudCardHeader>
                <MudCardContent Class="module-scroll">
                    <MudGrid Spacing="2">
                        <MudItem xs="12">
                            <MudTextField Label="任务号"
                                          Variant="Variant.Outlined"
                                          Dense="true"
                                          ReadOnly="true"
                                          Value="_draft.TaskNo" />
                        </MudItem>

                        <MudItem xs="12">
                            <MudTextField Label="载具/托盘号"
                                          Variant="Variant.Outlined"
                                          Dense="true"
                                          @bind-Value="_draft.CarrierCode" />
                        </MudItem>

                        <MudItem xs="12">
                            <MudTextField Label="起点位"
                                          Variant="Variant.Outlined"
                                          Dense="true"
                                          @bind-Value="_draft.SourceLocation" />
                        </MudItem>

                        @if (_config.TaskType == "TWD出库" || _config.TaskType == "TWD入库" )
                        {
                            <MudItem xs="12">
                                <MudTextField Label="接驳位点位"
                                              Variant="Variant.Outlined"
                                              Dense="true"
                                              @bind-Value="_draft.TransferLocation" />
                            </MudItem>
                        }

                        <MudItem xs="12">
                            <MudTextField Label="目标位"
                                          Variant="Variant.Outlined"
                                          Dense="true"
                                          @bind-Value="_draft.TargetLocation" />
                        </MudItem>

                        <MudItem xs="12" sm="6">
                            <MudNumericField T="int"
                                             Label="优先级"
                                             Variant="Variant.Outlined"
                                             Dense="true"
                                             Min="1"
                                             Max="5"
                                             @bind-Value="_draft.Priority" />
                        </MudItem>

                        <MudItem xs="12" sm="6">
                            <MudNumericField T="int"
                                             Label="数量"
                                             Variant="Variant.Outlined"
                                             Dense="true"
                                             Min="1"
                                             Max="9999"
                                             @bind-Value="_draft.Quantity" />
                        </MudItem>

                        <MudItem xs="12">
                            <MudSwitch T="bool"
                                       Color="Color.Primary"
                                       @bind-Value="_draft.IsUrgent">
                                紧急任务
                            </MudSwitch>
                        </MudItem>
                    </MudGrid>

                    <MudStack Row="true" Spacing="1" Class="mt-3 flex-wrap-gap">
                        <MudButton Variant="Variant.Outlined"
                                   Color="Color.Info"
                                   StartIcon="@Icons.Material.Filled.AutoAwesome"
                                   OnClick="GenerateDraftTaskNo">
                            生成任务号
                        </MudButton>

                        <MudButton Variant="Variant.Filled"
                                   Color="Color.Primary"
                                   StartIcon="@Icons.Material.Filled.AddTask"
                                   OnClick="AddToQueue">
                            加入待发队列
                        </MudButton>

                        <MudButton Variant="Variant.Filled"
                                   Color="Color.Success"
                                   StartIcon="@Icons.Material.Filled.Publish"
                                   OnClick="SendAll">
                            一键下发
                        </MudButton>
                    </MudStack>
                </MudCardContent>
            </MudCard>
        </MudItem>

        <!-- 待发队列 -->
        <MudItem xs="12" md="4" Class="top-module">
            <MudCard Class="modern-card h-100">
                <MudCardHeader>
                    <CardHeaderContent>
                        <MudText Typo="Typo.h6">
                            <MudIcon Icon="@Icons.Material.Filled.Inventory2" Class="mr-2" />
                            待发队列
                        </MudText>
                    </CardHeaderContent>
                </MudCardHeader>
                <MudCardContent Class="queue-panel-content">
                    <MudStack Row="true" Justify="Justify.SpaceBetween" AlignItems="AlignItems.Center" Class="mb-2">
                        <MudText Typo="Typo.subtitle2">任务列表</MudText>
                        <MudChip T="string" Variant="Variant.Outlined" Color="Color.Primary">
                            共 @_queuedTasks.Count 条
                        </MudChip>
                    </MudStack>

                    <div class="queue-scroll-full">
                        <MudTable Items="_queuedTasks" Dense="true" Hover="true" Striped="true" Elevation="0">
                            <HeaderContent>
                                <MudTh>任务号</MudTh>
                                <MudTh>类型</MudTh>
                                <MudTh>起点</MudTh>
                                <MudTh>接驳位点位</MudTh>
                                <MudTh>目标</MudTh>
                                <MudTh>优先级</MudTh>
                                <MudTh>状态</MudTh>
                                <MudTh>操作</MudTh>
                            </HeaderContent>
                            <RowTemplate>
                                <MudTd DataLabel="任务号">@context.TaskNo</MudTd>
                                <MudTd DataLabel="类型">@context.TaskType</MudTd>
                                <MudTd DataLabel="起点">@context.SourceLocation</MudTd>
                                <MudTd DataLabel="接驳位点位">@context.TransferLocation</MudTd>
                                <MudTd DataLabel="目标">@context.TargetLocation</MudTd>
                                <MudTd DataLabel="优先级">@context.Priority</MudTd>
                                <MudTd DataLabel="状态">
                                    <MudChip T="string"
                                             Color="@GetStatusColor(context.Status)"
                                             Variant="Variant.Filled"
                                             Size="Size.Small">
                                        @context.Status
                                    </MudChip>
                                </MudTd>
                                <MudTd DataLabel="操作">
                                    <MudButton Variant="Variant.Text"
                                               Color="Color.Success"
                                               Size="Size.Small"
                                               Disabled="@_sendingTaskNos.Contains(context.TaskNo)"
                                               OnClick="@(() => StartSendSingle(context))">
                                        @(_sendingTaskNos.Contains(context.TaskNo) ? "发送中..." : "下发")
                                    </MudButton>
                                </MudTd>
                            </RowTemplate>
                            <NoRecordsContent>
                                <MudText Color="Color.Secondary">暂无待发送任务</MudText>
                            </NoRecordsContent>
                        </MudTable>
                    </div>
                </MudCardContent>
            </MudCard>
        </MudItem>

        <!-- 日志界面 -->
        <MudItem xs="12" Class="bottom-module">
            <MudCard Class="modern-card h-100">
                <MudCardHeader>
                    <CardHeaderContent>
                        <MudText Typo="Typo.h6">
                            <MudIcon Icon="@Icons.Material.Filled.ReceiptLong" Class="mr-2" />
                            日志界面
                        </MudText>
                    </CardHeaderContent>
                </MudCardHeader>
                <MudCardContent Class="module-scroll">
                    <MudStack Row="true" Spacing="1" Class="mb-2">
                        <MudButton Variant="Variant.Outlined" Color="Color.Default" StartIcon="@Icons.Material.Filled.DeleteSweep" OnClick="ClearLogs">
                            清空日志
                        </MudButton>
                    </MudStack>

                    <MudTable Items="_logs.OrderByDescending(x => x.Time)" Dense="true" Hover="true" Striped="true" Elevation="0">
                        <HeaderContent>
                            <MudTh>时间</MudTh>
                            <MudTh>级别</MudTh>
                            <MudTh>内容</MudTh>
                        </HeaderContent>
                        <RowTemplate>
                            <MudTd DataLabel="时间">@context.Time.ToString("yyyy-MM-dd HH:mm:ss.fff")</MudTd>
                            <MudTd DataLabel="级别">
                                <MudChip T="string" Color="@GetLogColor(context.Level)" Variant="Variant.Outlined" Size="Size.Small">
                                    @context.Level
                                </MudChip>
                            </MudTd>
                            <MudTd DataLabel="内容">@context.Message</MudTd>
                        </RowTemplate>
                        <NoRecordsContent>
                            <MudText Color="Color.Secondary">暂无日志</MudText>
                        </NoRecordsContent>
                    </MudTable>
                </MudCardContent>
            </MudCard>
        </MudItem>
    </MudGrid>
</MudContainer>

<style>
    .wcs-page {
        background: linear-gradient(180deg, rgba(255,255,255,.02), rgba(255,255,255,0));
        min-height: calc(100vh - 90px);
    }

    .modern-card {
        border-radius: 16px;
        backdrop-filter: blur(2px);
        height: 100%;
    }

    .top-module {
        height: clamp(420px, 52vh, 620px);
    }

    .bottom-module {
        min-height: 320px;
    }

    .module-scroll {
        height: calc(100% - 78px);
        overflow-y: auto;
        overflow-x: hidden;
        padding-right: 4px;
    }

    .queue-panel-content {
        height: calc(100% - 78px);
        min-height: 0;
        display: flex;
        flex-direction: column;
    }

    .queue-scroll-full {
        flex: 1;
        min-height: 0;
        overflow-y: auto;
        overflow-x: hidden;
        padding-right: 4px;
    }

    .module-scroll::-webkit-scrollbar,
    .queue-scroll-full::-webkit-scrollbar {
        width: 8px;
    }

    .module-scroll::-webkit-scrollbar-thumb,
    .queue-scroll-full::-webkit-scrollbar-thumb {
        background: rgba(120, 120, 120, .35);
        border-radius: 8px;
    }

    .flex-wrap-gap {
        flex-wrap: wrap;
    }
</style>

@code {
    [Inject] private ISnackbar Snackbar { get; set; } = default!;

    private readonly HashSet<string> _sendingTaskNos = [];
    private readonly List<string> _targetSystems = ["RCS"];
    private readonly List<string> _taskTypes = ["普通入库", "普通出库", "TWD入库", "TWD出库", "TWD普通分拣", "TWD入库分拣"];

    private SimConfig _config = new()
    {
        TargetSystem = "RCS",
        WarehouseName = "Show",
        TaskType = "普通入库",
        DefaultPriority = 3,
        AutoAck = true
    };

    private DraftTask _draft = new();
    private readonly List<QueuedTask> _queuedTasks = [];
    private readonly List<LogEntry> _logs = [];

    protected override void OnInitialized()
    {
        GenerateDraftTaskNo();
        AddLog("INFO", "WCS 模拟台初始化完成");
    }

    private void SaveConfig()
    {
        if (_config.TaskType != "TWD出库")
        {
            _draft.TransferLocation = string.Empty;
        }

        AddLog("INFO", $"配置已保存：目标系统={_config.TargetSystem}, 仓库名={_config.WarehouseName}, 任务类型={_config.TaskType}");
        Snackbar.Add("配置已保存", Severity.Success);
    }

    private void ResetConfig()
    {
        _config = new SimConfig
        {
            TargetSystem = "RCS",
            WarehouseName = "Show",
            TaskType = "普通入库",
            DefaultPriority = 3,
            AutoAck = true
        };
        _draft.TransferLocation = string.Empty;

        AddLog("WARN", "配置已重置为默认值");
        Snackbar.Add("已重置默认配置", Severity.Warning);
    }

    private void GenerateDraftTaskNo()
    {
        _draft.TaskNo = $"TK{DateTime.Now:yyyyMMddHHmmssfff}";
    }

    private void AddToQueue()
    {
        if (string.IsNullOrWhiteSpace(_draft.CarrierCode) ||
            string.IsNullOrWhiteSpace(_draft.SourceLocation) ||
            string.IsNullOrWhiteSpace(_draft.TargetLocation))
        {
            Snackbar.Add("请填写载具号、起点位、目标位", Severity.Error);
            AddLog("ERROR", "任务创建失败：关键字段为空");
            return;
        }

        if (_config.TaskType == "TWD出库" &&
            string.IsNullOrWhiteSpace(_draft.TransferLocation))
        {
            Snackbar.Add("TWD出库任务必须填写接驳位点位", Severity.Error);
            AddLog("ERROR", "任务创建失败：TWD出库未填写接驳位点位");
            return;
        }

        var task = new QueuedTask
        {
            TaskNo = _draft.TaskNo,
            TaskType = MapTaskType(_config.TaskType),
            CarrierCode = _draft.CarrierCode,
            SourceLocation = _draft.SourceLocation,
            TransferLocation = _draft.TransferLocation,
            TargetLocation = _draft.TargetLocation,
            Warehouse = _config.WarehouseName,
            Priority = _draft.Priority,
            Quantity = _draft.Quantity,
            IsUrgent = _draft.IsUrgent,
            Status = "待发送",
            CreatedTime = DateTime.Now
        };

        _queuedTasks.Add(task);
        AddLog("INFO", $"任务已加入队列：{task.TaskNo} -> {_config.TargetSystem}");

        // _draft.CarrierCode = string.Empty;
        // _draft.SourceLocation = string.Empty;
        // _draft.TransferLocation = string.Empty;
        // _draft.TargetLocation = string.Empty;
        // _draft.Quantity = 1;
        // _draft.IsUrgent = false;
        // GenerateDraftTaskNo();

        Snackbar.Add("已加入待发队列", Severity.Success);
    }

    private Task StartSendSingle(QueuedTask task)
    {
        if (task.Status == "已发送" || _sendingTaskNos.Contains(task.TaskNo))
            return Task.CompletedTask;

        _sendingTaskNos.Add(task.TaskNo);
        StateHasChanged();

        _ = SendSingleInBackgroundAsync(task);
        return Task.CompletedTask;
    }

    private async Task SendSingleInBackgroundAsync(QueuedTask task)
    {
        try
        {
            var result = await TaskHttpService.SendTaskAsync(task, _config.TargetSystem);

            await InvokeAsync(() =>
            {
                if (!result.Success)
                {
                    AddLog("ERROR", $"任务下发失败：{task.TaskNo}，{result.Message}");
                    Snackbar.Add(result.Message, Severity.Error);
                    return;
                }

                task.Status = "已发送";
                AddLog("INFO", $"任务下发成功：{task.TaskNo}，目标系统：{_config.TargetSystem}");
                Snackbar.Add($"任务 {task.TaskNo} 已发送", Severity.Success);
            });
        }
        finally
        {
            await InvokeAsync(() =>
            {
                _sendingTaskNos.Remove(task.TaskNo);
                StateHasChanged();
            });
        }
    }

    private void SendAll()
    {
        var pending = _queuedTasks.Where(t => t.Status != "已发送").ToList();
        if (pending.Count == 0)
        {
            Snackbar.Add("没有可发送的任务", Severity.Info);
            return;
        }

        foreach (var task in pending)
        {
            task.Status = "已发送";
            AddLog("INFO", $"任务下发成功：{task.TaskNo}，目标系统：{_config.TargetSystem}");
        }

        Snackbar.Add($"已下发 {pending.Count} 条任务", Severity.Success);
    }

    private void ClearLogs()
    {
        _logs.Clear();
        Snackbar.Add("日志已清空", Severity.Normal);
    }

    private void AddLog(string level, string message)
    {
        _logs.Add(new LogEntry
        {
            Time = DateTime.Now,
            Level = level,
            Message = message
        });
    }

    private static Color GetStatusColor(string status) => status switch
    {
        "待发送" => Color.Warning,
        "已发送" => Color.Success,
        _ => Color.Default
    };

    private static Color GetLogColor(string level) => level switch
    {
        "INFO" => Color.Info,
        "WARN" => Color.Warning,
        "ERROR" => Color.Error,
        _ => Color.Default
    };

    private static string MapTaskType(string taskType) 
    => taskType switch
    {
        "普通入库" => "NORMAL_INBOUND",
        "普通出库" => "NORMAL_OUTBOUND",
        "TWD入库" => "CONTAINER_INBOUND",
        "TWD出库" => "CONTAINER_OUTBOUND",
        "TWD普通分拣" => "CONTAINER_SORTING",
        "TWD入库分拣" => "CONTAINER_INBOUND_SORTING",
        _ => taskType
    };
}