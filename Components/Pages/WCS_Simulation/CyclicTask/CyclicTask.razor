@page "/wcs-simulation/cyclic-task"

@using LY_WebUI_Mudblazor_net8.Components.Pages.WCS_Simulation.CyclicTask.Services
@using LY_WebUI_Mudblazor_net8.Components.Pages.WCS_Simulation.CyclicTask.Models
@using LY_WebUI_Mudblazor_net8.Components.Pages.WCS_Simulation.CyclicTask.Services.TWDproject
@using LY_WebUI_Mudblazor_net8.Components.Pages.WCS_Simulation.Shared.Services
@using MudBlazor

@inject IRcsDbService RcsDbService
@inject ICyclicTasksIssuing CyclicTasksIssuing
@inject ISnackbar Snackbar
@inject IAppMemoryStore _appMemoryStore
@inject TWDproject TWDproject
@inject NavigationManager NavManager

<MudContainer MaxWidth="MaxWidth.False" Class="pa-4">
    <MudGrid Spacing="3">
        <!-- 左列：RCS 连接 / 周期任务控制 -->
        <MudItem xs="12" md="3">
            <MudCard Class="modern-card h-100">
                <MudCardHeader>
                    <CardHeaderContent>
                        <MudText Typo="Typo.h6">
                            <MudIcon Icon="@Icons.Material.Filled.Storage" Class="mr-2" />
                            RCS 连接设置
                        </MudText>
                    </CardHeaderContent>
                </MudCardHeader>

                <MudCardContent>
                    <MudStack Spacing="2">
                        <MudTextField Label="RCS 主机/IP" Variant="Variant.Outlined" Dense="true" @bind-Value="_cfg.Host" />
                        <MudNumericField T="int" Label="端口" Variant="Variant.Outlined" Dense="true" Min="1" Max="65535" @bind-Value="_cfg.Port" />
                        <MudTextField Label="用户名" Variant="Variant.Outlined" Dense="true" @bind-Value="_cfg.User" />
                        <MudTextField Label="密码" Variant="Variant.Outlined" Dense="true" InputType="InputType.Password" @bind-Value="_cfg.Password" />
                        <MudTextField Label="数据库名" Variant="Variant.Outlined" Dense="true" @bind-Value="_cfg.Database" />

                        <MudStack Row="true" Spacing="1" AlignItems="AlignItems.Center" Class="conn-controls">
                            <div class="btn-group">
                                <MudButton Variant="Variant.Filled" Color="Color.Primary" OnClick="TestConnectionAsync" StartIcon="@Icons.Material.Filled.WifiTethering">
                                    测试连接（并保存配置）
                                </MudButton>
                                <MudButton Variant="Variant.Outlined" Color="Color.Default" OnClick="DisconnectAsync" StartIcon="@Icons.Material.Filled.LinkOff">
                                    断开数据库
                                </MudButton>
                            </div>
                        </MudStack>

                        <div class="status-wrapper">
                            <MudText Typo="Typo.caption" Class="status-text ml-2">@LastCheckedText</MudText>
                        </div>

                        <!-- 替换原来显示连接状态的 <div> 节点，保留其周边结构 -->
                        <div class="status-and-inventory" style="display:flex;align-items:center;gap:12px;">
                            <div>
                                <MudText Typo="Typo.subtitle2">连接状态</MudText>
                                <MudChip T="string" Color="@GetStatusColorFromCfg()" Variant="Variant.Filled" StartIcon="@GetStatusIconFromCfg()">
                                    @_cfg.ConnectionState.ToString()
                                </MudChip>
                            </div>

                            <!-- 库存信息（托盘架 / 货物），点击可刷新 -->
                            <div style="margin-left:auto; display:flex; gap:8px; align-items:center;">
                                <MudPaper Elevation="0" Class="pa-2" Style="display:flex;gap:8px;align-items:center;">
                                    <MudStack Row="true" AlignItems="AlignItems.Center" Spacing="1">
                                        <MudText Typo="Typo.caption" Class="mb-0">库存</MudText>
                                        <div style="display:flex;gap:6px;align-items:center;">
                                            <MudChip T="string" Color="Color.Primary" Variant="Variant.Outlined" Size="Size.Small" StartIcon="@Icons.Material.Filled.Storage">
                                                托盘: @_totalTrays
                                            </MudChip>
                                            <MudChip T="string" Color="Color.Secondary" Variant="Variant.Outlined" Size="Size.Small" StartIcon="@Icons.Material.Filled.LocalShipping">
                                                货物: @_totalCargo
                                            </MudChip>
                                            <MudIconButton Icon="@Icons.Material.Filled.Refresh" Size="Size.Small" Color="Color.Default" OnClick="RefreshInventoryAsync" />
                                        </div>
                                    </MudStack>
                                </MudPaper>
                            </div>
                        </div>

                        <MudDivider Class="my-2" />

                        <MudText Typo="Typo.h6">周期任务</MudText>

                        <MudStack Spacing="1">
                            <MudSelect T="string" Label="选择项目/周期任务" Variant="Variant.Outlined" Dense="true" @bind-Value="_selectedProject">
                                @foreach (var p in _projectOptions)
                                {
                                    <MudSelectItem T="string" Value="@p">@p</MudSelectItem>
                                }
                            </MudSelect>
                            <MudItem xs="12">
                                <MudTextField Label="执行次数"
                                              Variant="Variant.Outlined"
                                              Dense="true"
                                              @bind-Value="_cycleTimes" />
                            </MudItem>

                            <MudStack Row="true" Spacing="1" AlignItems="AlignItems.Center">
                                <MudButton Variant="Variant.Filled" Color="Color.Success" OnClick="StartCycle" StartIcon="@Icons.Material.Filled.PlayArrow" Disabled="@string.IsNullOrWhiteSpace(_selectedProject)">
                                    开始
                                </MudButton>
                                <MudButton Variant="Variant.Outlined" Color="Color.Error" OnClick="StopCycle" StartIcon="@Icons.Material.Filled.Stop" Disabled="@string.IsNullOrWhiteSpace(_selectedProject)">
                                    停止
                                </MudButton>
                            </MudStack>

                            <MudText Typo="Typo.caption" Class="mt-2" Style="@(_selectedProject != null ? "color: green;" : "")">
                                已选： @(_selectedProject ?? "未选择")
                            </MudText>
                            <MudText Typo="Typo.caption" Class="mt-2">@_logText</MudText>
                            <MudText Typo="Typo.caption" Class="mt-1">说明：根据选择的项目，后台会执行对应周期任务</MudText>
                        </MudStack>

                    </MudStack>
                </MudCardContent>
            </MudCard>
        </MudItem>

        <!-- 中间列：业务流程（使用外层 div 捕获点击事件，确保 @onclick 被触发） -->
        <MudItem xs="12" md="3">
            <div @onclick="OnBusinessFlowClicked" style="cursor:pointer;">
                <MudCard Class="modern-card business-flow-preview"
                         Style="@(_selectedProject == "泰国TWD项目" ? "border:1px solid rgba(0,0,0,0.06);" : "")">
                    <MudCardHeader>
                        <CardHeaderContent>
                            <MudText Typo="Typo.h6">
                                <MudIcon Icon="@Icons.Material.Filled.Settings" Class="mr-2" />
                                业务流程
                                <span style="font-size:0.85rem;color:var(--mud-palette-text-secondary);margin-left:8px;">
                                    (@(_selectedProject ?? "未选择具体项目"))
                                </span>
                            </MudText>
                        </CardHeaderContent>
                        <CardHeaderActions>
                            @if (_selectedProject == "泰国TWD项目")
                            {
                                <MudChip T="string" Color="Color.Info" Size="Size.Small">查看详情</MudChip>
                            }
                            else
                            {
                                <MudChip T="string" Color="Color.Default" Size="Size.Small">仅预览</MudChip>
                            }
                        </CardHeaderActions>
                    </MudCardHeader>

                    <MudCardContent>
                        <MudStack Spacing="2">
                            <MudPaper Elevation="0" Class="pa-2" Style="border-radius:6px;">
                                <MudText Typo="Typo.body2" Class="mb-0">
                                    本业务流程依赖于 GRCS 10.1 及以上版本。
                                </MudText>
                            </MudPaper>

                            <div>
                                <MudText Typo="Typo.subtitle2" Class="mb-1">接驳位信号下发（示意）</MudText>
                                <MudGrid Gutter="2">
                                    @for (int i = 1; i <= 10; i++)
                                    {
                                        <MudItem xs="6" sm="4" md="2">
                                            <MudButton Variant="Variant.Outlined" Color="Color.Primary" Class="w-100" Disabled="true">
                                                接驳 @i
                                            </MudButton>
                                        </MudItem>
                                    }
                                </MudGrid>
                            </div>

                            <div>
                                <MudText Typo="Typo.subtitle2" Class="mb-1">分拣台信号下发（示意）</MudText>
                                <MudGrid Gutter="2">
                                    @for (int i = 1; i <= 10; i++)
                                    {
                                        <MudItem xs="6" sm="4" md="2">
                                            <MudButton Variant="Variant.Outlined" Color="Color.Secondary" Class="w-100" Disabled="true">
                                                分拣 @i
                                            </MudButton>
                                        </MudItem>
                                    }
                                </MudGrid>
                            </div>
                        </MudStack>
                    </MudCardContent>
                </MudCard>
            </div>
        </MudItem>

        <!-- 右列：任务看板（从内存读取并展示） -->
        <MudItem xs="12" md="6">
            <MudCard Class="modern-card h-100">
                <MudCardHeader>
                    <CardHeaderContent>
                        <MudText Typo="Typo.h6">
                            <MudIcon Icon="@Icons.Material.Filled.Dashboard" Class="mr-2" />
                            周期任务看板
                        </MudText>
                    </CardHeaderContent>

                    <CardHeaderActions>
                        <MudStack Row="true" Spacing="1" AlignItems="AlignItems.Center">
                            <MudButton Variant="Variant.Outlined" Color="Color.Error" OnClick="ClearBoard" StartIcon="@Icons.Material.Filled.Delete">
                                清空
                            </MudButton>
                            <MudText Typo="Typo.caption" Class="ml-2">每页</MudText>
                            <MudSelect T="int" @bind-Value="_pageSize" Dense="true" Style="width:80px">
                                <MudSelectItem T="int" Value="10">10</MudSelectItem>
                                <MudSelectItem T="int" Value="20">20</MudSelectItem>
                                <MudSelectItem T="int" Value="50">50</MudSelectItem>
                            </MudSelect>
                        </MudStack>
                    </CardHeaderActions>
                </MudCardHeader>

                <!-- MudCardContent 依然是 flex 列布局，用于固定页脚 -->
                <MudCardContent Class="module-scroll d-flex flex-column">
                    <!-- 可滚动列表区域：设置固定高度 -->
                    <div class="board-scroll">
                        <MudTable Dense="true" Hover="true" Items="_pagedBoardTasks">
                            <HeaderContent>
                                <MudTh>任务号</MudTh>
                                <MudTh>类型</MudTh>
                                <MudTh>来源</MudTh>
                                <MudTh>目标</MudTh>
                                <MudTh>优先级</MudTh>
                                <MudTh>状态</MudTh>
                            </HeaderContent>
                            <RowTemplate>
                                <MudTd DataLabel="任务号">@context.TaskNo</MudTd>
                                <MudTd DataLabel="类型">@context.TaskType</MudTd>
                                <MudTd DataLabel="来源">@context.SourceLocation</MudTd>
                                <MudTd DataLabel="目标">@context.TargetLocation</MudTd>
                                <MudTd DataLabel="优先级">@context.Priority</MudTd>
                                <MudTd DataLabel="状态">
                                    <MudChip T="string" Color="@GetStatusColor(context.Status)" Size="Size.Small">@context.Status</MudChip>
                                </MudTd>
                            </RowTemplate>
                        </MudTable>
                    </div>

                    <!-- 固定在卡片底部的分页/操作区 -->
                    <div class="board-footer">
                        <MudStack Row="true" Spacing="1" AlignItems="AlignItems.Center">
                            <MudButton Variant="Variant.Outlined" OnClick="PrevPage" Disabled="@(_currentPage <= 1)">
                                <MudIcon Icon="@Icons.Material.Filled.ChevronLeft" />
                            </MudButton>
                            <MudText Typo="Typo.subtitle2">第 @_currentPage / @_totalPages 页</MudText>
                            <MudButton Variant="Variant.Outlined" OnClick="NextPage" Disabled="@(_currentPage >= _totalPages)">
                                <MudIcon Icon="@Icons.Material.Filled.ChevronRight" />
                            </MudButton>
                            <MudText Typo="Typo.caption">共 @_totalItems 条</MudText>
                        </MudStack>
                    </div>
                </MudCardContent>
            </MudCard>
        </MudItem>
    </MudGrid>
</MudContainer>

<style>
    /*左列右列样式 */
    /* 使 modern-card 有默认卡片外观并支持伸缩布局 */
    .modern-card {
        border-radius: 8px;
        box-shadow: 0 1px 6px rgba(0,0,0,0.08);
        background: var(--mud-palette-surface, #fff);
        overflow: hidden;
        display: flex;
        flex-direction: column;
    }

    /* h-100 表示占满父容器高度（配合 Grid/Item 使用） */
    .h-100 {
        height: 100%;
        min-height: 0;
    }


    /* btn-group 固定只包裹按钮，不随状态文本变化伸缩 */
    .conn-controls .btn-group {
        display: flex;
        gap: 8px;
        flex: 0 0 auto;
        align-items: center;
    }

    /* status-wrapper 放在右侧，宽度固定或最大宽度，文本溢出省略 */
    .conn-controls .status-wrapper {
        display: flex;
        align-items: center;
        margin-left: auto; /* 推到最右侧 */
        min-width: 180px; /* 根据需要调整 */
        max-width: 320px;
        flex: 0 0 auto;
    }

    /* 状态文本不换行，超出显示省略号 */
    .status-text {
        display: block;
        width: 100%;
        white-space: nowrap;
        overflow: hidden;
        text-overflow: ellipsis;
    }

    .module-scroll.d-flex.flex-column {
        height: 100%;
        /* 确保 MudCardContent 作为一个垂直弹性盒子 */
    }

    .board-scroll {
        /* 设置一个固定的高度，例如显示大约 10 行数据 */
        height: 800px; /* 您可以根据需要调整这个值 */
    
        /* 或者设置最大高度，这样在数据很少时不会浪费空间，数据多时也不会超过限制 */
        /* max-height: 400px; */

        overflow-y: auto; /* 当内容超出设定的高度时，显示垂直滚动条 */
    }

    .board-footer {
        height: 60px;
        display: flex;
        align-items: center;
        justify-content: space-between;
        padding: 8px 16px;
        border-top: 1px solid rgba(0,0,0,.12);
        /* 由于父容器是 flex-column，这个 margin-top: auto 会将页脚推到底部 */
        margin-top: auto;
    }

    </style>

@code {
    [Inject] private ISnackbar SnackbarInject { get; set; } = default!;

    private RcsConnectionConfig _cfg = new();

    // 看板数据模型
    private sealed record BoardTask(string TaskNo, string TaskType, string SourceLocation, string TargetLocation, int Priority, string Status);

    private string _lastCheckedText = "未检测";
    public string LastCheckedText
    {
        get => _lastCheckedText;
        private set
        {
            _lastCheckedText = value;
            LogStatusChange(_lastCheckedText);
        }
    }

    private string _logText = $"{DateTime.Now:HH:mm:ss} [info] 等待下发周期任务";

    private CancellationTokenSource? _monitorCts;
    private bool _cycleRunning = false;

    private string? _selectedProject;
    private readonly List<string> _projectOptions = new()
    {
        "泰国TWD项目",
        "项目B",
        "项目C"
    };

    // 执行次数
    private int _cycleTimes = 10;

    // 内存中读取的原始 Board 列表（全量）
    private List<BoardTask> _boardTasks = new();

    // 当前页显示的数据
    private List<BoardTask> _pagedBoardTasks = new();

    // 轮询内存的任务（读取 DeliveryResult 列表）并刷新 UI
    private CancellationTokenSource? _boardMonitorCts;

    // 分页 / 昔令控制
    private int _pageSize = 20;
    private int _currentPage = 1;
    private int _totalPages = 1;
    private int _totalItems = 0;
    private bool _ascending = true; // 顺序显示 (true = 旧到新)

    // 新增字段（放在其它私有字段附近）
    private int _totalTrays = 0;
    private int _totalCargo = 0;
    private bool _inventoryLoading = false;

    protected async override void OnInitialized()
    {
        var stored = _appMemoryStore.GetOrDefault<RcsConnectionConfig>();
        if (stored is not null)
        {
            _cfg = stored.Clone();
            LastCheckedText = stored.LastCheckedUtc.HasValue
                ? $"已加载：{stored.LastCheckedUtc.Value.ToLocalTime():yyyy-MM-dd HH:mm:ss} {stored.LastStatusMessage}"
                : "已加载内存配置";
        }
        await RefreshInventoryAsync();
        StartBoardMonitor();
	}

	private void StartBoardMonitor()
	{
		_boardMonitorCts?.Cancel();
		_boardMonitorCts = new CancellationTokenSource();
		var ct = _boardMonitorCts.Token;

		_ = Task.Run(async () =>
		{
			while (!ct.IsCancellationRequested)
			{
				try
				{
					await LoadBoardTasksFromMemoryAsync();
					await Task.Delay(1000, ct); // 每秒刷新一次
				}
				catch (OperationCanceledException) when (ct.IsCancellationRequested) { break; }
				catch { /* 忽略单次错误，继续轮询 */ }
			}
		}, ct);
	}

	private async Task LoadBoardTasksFromMemoryAsync()
	{
		var results = _appMemoryStore.GetOrDefault<List<DeliveryResult>>() ?? new List<DeliveryResult>();

		IEnumerable<DeliveryResult> ordered = _ascending ? results.AsEnumerable() : results.AsEnumerable().Reverse();

		var mapped = ordered
			.Select(dr => new BoardTask(
				dr.Task.TaskNo,
				dr.Task.TaskType,
				dr.Task.SourceLocation,
				dr.Task.TargetLocation,
				dr.Task.Priority,
				dr.Status.ToString()))
			.ToList();

		// 更新全量与分页信息
		_boardTasks = mapped;
		_totalItems = _boardTasks.Count;
		_pageSize = Math.Max(1, _pageSize);
		_totalPages = Math.Max(1, (_totalItems + _pageSize - 1) / _pageSize);

		// clamp page
		if (_currentPage > _totalPages) _currentPage = _totalPages;
		if (_currentPage < 1) _currentPage = 1;

		_pagedBoardTasks = _boardTasks.Skip((_currentPage - 1) * _pageSize).Take(_pageSize).ToList();

		await InvokeAsync(StateHasChanged);
	}

	private void ClearBoard()
	{
		lock (_boardMonitorCts ?? new CancellationTokenSource()) // simple lock object substitute
		{
			_appMemoryStore.Set(new List<DeliveryResult>());
			_currentPage = 1;
		}

		_ = LoadBoardTasksFromMemoryAsync();
	}

    private void PrevPage()
    {
        if (_currentPage <= 1) return;
        _currentPage--;
        _ = LoadBoardTasksFromMemoryAsync();
    }

    private void NextPage()
    {
        if (_currentPage >= _totalPages) return;
        _currentPage++;
        _ = LoadBoardTasksFromMemoryAsync();
    }

    private void StartCycle()
    {
        if (string.IsNullOrWhiteSpace(_selectedProject))
        {
            AddLog("WARN", "请先选择项目周期任务");
            return;
        }

        if (_cfg.ConnectionState != ConnState.Connected)
        {
            AddLog("ERROR", "数据库未连接，请先测试并确认连接状态为 Connected");
            return;
        }

        _cycleRunning = true;
        AddLog("INFO", $"已启动周期任务：{_selectedProject}");

        var times = ParseCycleTimes();

        if (_selectedProject == "泰国TWD项目")
            _ = TWDproject.Thailand_TWD(times);
    }

    private int ParseCycleTimes() => Math.Max(1, _cycleTimes);

    private void StopCycle()
    {
        if (!_cycleRunning)
        {
            AddLog("WARN", "周期任务未在运行");
            return;
        }

        _cycleRunning = false;
        AddLog("INFO", $"已停止周期任务：{_selectedProject}");
    }

    private async Task TestConnectionAsync()
    {
        var stored = _appMemoryStore.GetOrDefault<RcsConnectionConfig>();
        var toSave = _cfg.Clone();
        if (stored is not null)
        {
            toSave.ConnectionState = stored.ConnectionState;
            toSave.LastStatusMessage = stored.LastStatusMessage;
            toSave.LastCheckedUtc = stored.LastCheckedUtc;
        }
        _appMemoryStore.Set(toSave);

        await InvokeAsync(StateHasChanged);

        using var cts = new CancellationTokenSource(TimeSpan.FromSeconds(Math.Max(1, _cfg.ConnectTimeoutSeconds)));
        var ok = await RcsDbService.TestConnectionAsync(cts.Token);

        // 测试连接后立即读取库存并显示（失败也尝试读取以反映最新）
        try
        {
            var (trays, cargo) = await CyclicTasksIssuing.CalculateInventory();
            _totalTrays = trays;
            _totalCargo = cargo;
        }
        catch
        {
            // 可选：记录或通知
            Snackbar?.Add("读取库存失败", Severity.Warning);
        }

        _cfg = _appMemoryStore.GetOrDefault<RcsConnectionConfig>() ?? new RcsConnectionConfig();
        LastCheckedText = _cfg.LastCheckedUtc.HasValue
            ? ($"上次检测: {_cfg.LastCheckedUtc.Value.ToLocalTime():yyyy-MM-dd HH:mm:ss} {_cfg.LastStatusMessage}")
            : $"{DateTime.Now:HH:mm:ss} 测试完成";

        await InvokeAsync(StateHasChanged);
    }

    private async Task DisconnectAsync()
    {
        await RcsDbService.DisconnectAsync();
        _monitorCts?.Cancel();
        _monitorCts = null;

        _cfg = _appMemoryStore.GetOrDefault<RcsConnectionConfig>() ?? new RcsConnectionConfig();
        LastCheckedText = $"{DateTime.Now:yyyy-MM-dd HH:mm:ss} 数据库已断开";
        await InvokeAsync(StateHasChanged);
    }

    // 手动刷新库存（供刷新按钮使用）
    private async Task RefreshInventoryAsync()
    {
        _inventoryLoading = true;
        try
        {
            var (trays, cargo) = await CyclicTasksIssuing.CalculateInventory();
            _totalTrays = trays;
            _totalCargo = cargo;
            Snackbar?.Add("刷新库存成功", Severity.Success);
        }
        catch
        {
            // 忽略错误或显示提示
            Snackbar?.Add("刷新库存失败", Severity.Warning);
        }
        finally
        {
            _inventoryLoading = false;
            await InvokeAsync(StateHasChanged);
        }
    }

    private void AddLog(string level, string message)
    {
        _logText = $"{DateTime.Now:HH:mm:ss} [{level}] {message}";
        InvokeAsync(StateHasChanged);

        var severity = level switch
        {
            "ERROR" => Severity.Error,
            "WARN" => Severity.Warning,
            "INFO" => Severity.Success,
            _ => Severity.Normal
        };

        try
        {
            Snackbar?.Add(message, severity);
        }
        catch { }
    }

    private Color GetStatusColorFromCfg()
    {
        var s = _cfg.ConnectionState.ToString();
        return s switch
        {
            "Connected" => Color.Success,
            "Testing" => Color.Info,
            "Disconnected" => Color.Error,
            _ => Color.Default
        };
    }

    private string GetStatusIconFromCfg()
    {
        var s = _cfg.ConnectionState.ToString();
        return s switch
        {
            "Connected" => Icons.Material.Filled.CheckCircle,
            "Testing" => Icons.Material.Filled.Autorenew,
            "Disconnected" => Icons.Material.Filled.Warning,
            _ => Icons.Material.Filled.HelpOutline
        };
    }

    private Color GetStatusColor(string status) => status switch
    {
        "待处理" => Color.Warning,
        "处理中" => Color.Info,
        "已完成" => Color.Success,
        "PENDING" => Color.Warning,
        "IN_PROGRESS" => Color.Info,
        "DONE" => Color.Success,
        _ => Color.Default
    };

    public void Dispose()
    {
        _monitorCts?.Cancel();
        _monitorCts?.Dispose();

        _boardMonitorCts?.Cancel();
        _boardMonitorCts?.Dispose();
    }

    private void LogStatusChange(string statusText)
    {
        string logLevel;
        if (statusText.Contains("成功") || statusText.Contains("Connected"))
            logLevel = "INFO";
        else if (statusText.Contains("失败") || statusText.Contains("Disconnected") || statusText.Contains("错误"))
            logLevel = "ERROR";
        else if (statusText.Contains("断开") || statusText.Contains("Warning"))
            logLevel = "WARN";
        else
            logLevel = "INFO";

        AddLog(logLevel, statusText);
    }

    private void NavigateToBusinessFlow()
    {
        if (_selectedProject == "泰国TWD项目")
        {
            NavManager.NavigateTo("/wcs-simulation/cyclic-task/business-flow");
        }
        else
        {
            Snackbar?.Add("请选择 泰国TWD项目 后查看业务流程详情", Severity.Warning);
        }
    }

    private Task OnBusinessFlowClicked()
    {
        if (_selectedProject == "泰国TWD项目")
        {
            NavigateToBusinessFlow();
        }
        else if (_selectedProject == "项目B")
        {
            Snackbar?.Add("项目B未开发", Severity.Warning);
        }
        else if (_selectedProject == "项目C")
        {
            Snackbar?.Add("项目C未开发", Severity.Warning);
        }
        else
        {
            Snackbar?.Add("未选择对应项目", Severity.Warning);
        }

        return Task.CompletedTask;
    }
}